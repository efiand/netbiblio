{% extends template %}

{% set title = "Алексей Сыманович" %}
{% set pubdate = "20.11.2011" %}
{% set contact = "mailto:pravednik1985@tut.by" %}
{% set prev = "decadent/index" %}
{% set next = "alra/index" %}
{% set openGraphImg = "pravednik.png" %}
{% set openGraphImgType = "image/png" %}
{% set openGraphImgWidth = 300 %}
{% set openGraphImgHeight = 384 %}
{% set openGraphImgAlt = "Портрет автора" %}
{% set gender = "male" %}
{% set tocBlockHeading = "Стихотворения" %}
{% set biographyHeading = "Об авторе" %}

{% block toc %}
  <h3 class="page__toc-title">25 шагов к Декадансу</h3>
  {{worksCollection("steps")}}
{% endblock %}

{% block biography %}
  {% filter prose %}
    Сыманович Алексей Александрович. Родился в 1985 году в городе Лиде (Республика Беларусь). Преподаватель русского языка и литературы. Магистр филологических наук. Лауреат Юбилейного X Международного Пушкинского конкурса (г. Москва). Лауреат II областного фестиваля «Поэзия — души движение» (победитель в номинации «О человеке, жизни и любви»). Автор сборника стихотворений «12 истин». С 2007 года женат на Оксане Анатольевне Супранович. Вместе растим дочь Марию.
    В качестве поэтического кредо взял бы слова В. Гюго: «Поэт — это философ конкретного и живописец абстрактного…»
  {% endfilter %}

  {{authorLinks("//alexej-symanovich.narod.ru")}}

  {{figure("pravednik.jpg", "Алексей Сыманович", "", openGraphImgWidth, openGraphImgHeight)}}
{% endblock %}

{% block reviews %}
  {% filter review("Эмилия", "netbiblio@pineglade.ru", "14.12.2011 22:36") %}
    Чудесные стихи! Очень жизненные и тонкие в то же время! Я восхищена!
  {% endfilter %}
{% endblock %}
