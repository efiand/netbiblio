{% extends template %}

{% set title = "Светлое Христово Воскресение" %}
{% set pubdate = "05.11.2003" %}
{% set workdate = "26.04.2003" %}
{% set workplace = "Лигово" %}

{% block content %}
  {% filter poem %}
    Светлое Христово Воскресение
    Мир встречает, радостью дыша:
    Подарил Господь тепло весеннее —
    И ликует каждая душа!

    С первыми лучами золотистыми
    Встану в ожидании чудес,
    Посмотрю с надеждой в небо чистое —
    И скажу: «Воистину воскрес!»
  {% endfilter %}
{% endblock %}
