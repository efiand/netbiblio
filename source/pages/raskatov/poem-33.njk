{% extends template %}

{% set title = "Привет Весны" %}
{% set pubdate = "05.11.2006" %}
{% set workdate = "29.03.2006" %}
{% set workplace = "Лигово" %}

{% block content %}
  {% filter poem %}
    Капает дождь на лёд,
    Тает сугроб водой —
    Это Весна идёт
    В царство Зимы седой.

    С окон уходит пар
    Струйке табачной вслед —
    Это весёлый Март
    Передаёт привет.
  {% endfilter %}
{% endblock %}
