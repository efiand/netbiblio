{% extends template %}

{% set title = "Образ Петербурга" %}
{% set pubdate = "05.11.2003" %}
{% set workdate = "29.04.2003" %}
{% set workplace = "Лигово" %}

{% block content %}
  {% filter poem %}
    Поведай мне, Нева,
    Одну из мудрых притч.
    Раскрой мне, Летний сад,
    Секрет твоих скульптур.
    Дворцы, спасибо вам
    За то, что смог постичь
    Убранство колоннад
    И ритмы каннелюр.

    Спасибо, град Петра,
    За ночи над Невой,
    За утренний туман,
    За суматоху дня.
    Из памяти стирать
    Твой образ золотой
    Я никому не дам —
    Ведь он хранит меня.
  {% endfilter %}
{% endblock %}
