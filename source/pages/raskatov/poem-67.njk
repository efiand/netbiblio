{% extends template %}

{% set title = "Мой любимый город" %}
{% set pubdate = "05.11.2003" %}
{% set workdate = "29.04.2003" %}
{% set workplace = "Лигово" %}

{% block content %}
  {% filter poem %}
    Строгость форм и блеск узоров,
    Шумных улиц прямота —
    Это мой любимый город,
    Воплощённая мечта.

    В нём — России честь и гордость:
    Миллионы светлых лиц,
    Честность слов и воли твёрдость,
    Мудрость авторских страниц.
  {% endfilter %}
{% endblock %}
