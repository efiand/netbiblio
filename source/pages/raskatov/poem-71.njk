{% extends template %}

{% set title = "Рисунок Весны" %}
{% set pubdate = "05.11.2003" %}
{% set workdate = "22.04.2003" %}
{% set workplace = "Лигово" %}

{% block content %}
  {% filter poem %}
    Белый лист раскрасился
    Солнцем золотистым,
    Листьев изумрудом,
    Желтизной цветка…
    Пусть зима не ластится
    К мягкой этой кисти!
    Белыми пусть будут
    Только облака.
  {% endfilter %}
{% endblock %}
