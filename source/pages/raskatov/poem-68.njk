{% extends template %}

{% set title = "Лицо Ирака" %}
{% set pubdate = "05.11.2003" %}
{% set workdate = "29.04.2003" %}
{% set workplace = "Лигово" %}

{% block content %}
  {% filter poem %}
    Сказали речь свою снаряды,
    Бойцы о доме видят сны.
    Пусть спят и жители Багдада,
    Пусть снится им лицо страны —

    Не то, что перебито ныне:
    Когда сорвут с него бинты,
    Увидят люди, что под ними —
    Американские черты.
  {% endfilter %}
{% endblock %}
