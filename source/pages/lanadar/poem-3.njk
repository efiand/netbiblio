{% extends template %}

{% set title = "«Не обрекайте Женщину на одиночество…»" %}
{% set pubdate = "31.10.2011" %}

{% block content %}
  {% filter poem %}
    Не обрекайте Женщину на одиночество!
    Не воздвигайте стен вокруг неё:
    Её алтарь несёт в себе пророчество
    На будущее ваше Бытиё!
  {% endfilter %}
{% endblock %}
