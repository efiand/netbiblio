{% extends template %}

{% set title = "«Дежурный фонарик, дежурный свисток…»" %}
{% set workdate = "13.09.2008" %}
{% set pubdate = "17.04.2008" %}
{% set next = "lidija_seljagina/signs-7-1" %}

{% block content %}
  {% filter poem %}
    Дежурный фонарик, дежурный свисток,
    И мой карандашик для нескольких строк,
    И шуточек всяких дежурный мешок —
    Чтоб мир не казался опасным
    И небо всегда было ясным.
  {% endfilter %}
{% endblock %}
