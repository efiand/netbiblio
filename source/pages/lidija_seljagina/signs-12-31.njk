{% extends template %}

{% set title = "«О снисхожденье, я тебя боюсь…»" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    О снисхожденье, я тебя боюсь!
    О жалость, и тебя я ненавижу!
    Лишь в честности и откровенье вижу
    Я тот магнит, к которому стремлюсь!
  {% endfilter %}
{% endblock %}

{% block dateplace %}
  <time class="page__workdate" datetime="1992">1992</time>
{% endblock %}
