{% extends template %}

{% set title = "«Пролетело лето, пролетело…»" %}
{% set workdate = "10.09.2007" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    Пролетело лето, пролетело.
    Жёлтым глазом осень заиграла,
    И росой холодной заблестела
    Зелень, что пожить ещё мечтала.
  {% endfilter %}
{% endblock %}
