{% extends template %}

{% set title = "«Какая тишина в моей душе…»" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    Какая тишина в моей душе!
    Какая отрешённость от невзгод!
    И страшно мне за эту тишину,
    И страшно мне заглядывать вперёд!
  {% endfilter %}
{% endblock %}

{% block dateplace %}
  <time class="page__workdate" datetime="1963">1963</time>
{% endblock %}
