{% extends template %}

{% set title = "«У каждого — свой личный лексикон…»" %}
{% set workdate = "28.04.2005" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    У каждого — свой личный лексикон,
    Свои слова, словечки и словищи.
    Свои глаза, и глазки, и глазищи,
    И каждому присущ свой личный тон.
  {% endfilter %}
{% endblock %}
