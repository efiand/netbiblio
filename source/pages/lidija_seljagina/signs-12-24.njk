{% extends template %}

{% set title = "«Я не умею писать иначе…»" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    Я не умею писать иначе,
    А может быть, даже и не хочу.
    Истина, принцип, разум горячий —
    Вот именно так я и жить хочу.
  {% endfilter %}
{% endblock %}

{% block dateplace %}
  <time class="page__workdate" datetime="1970">1970</time>
{% endblock %}
