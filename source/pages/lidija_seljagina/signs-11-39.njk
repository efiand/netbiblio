{% extends template %}

{% set title = "«И каждый раз, когда рассвет хорош…»" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    И каждый раз, когда рассвет хорош,
    Бездонно небо и сияньем сине,
    Воспоминанья детства растревожь —
    И будет мир и добрым, и любимым.
  {% endfilter %}
{% endblock %}

{% block dateplace %}
  <time class="page__workdate" datetime="2004-09">Сентябрь 2004</time>
{% endblock %}
