{% extends template %}

{% set title = "«Не перестану деньги занимать…»" %}
{% set workdate = "03.02.2005" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    Не перестану деньги занимать,
    Не перестану от души смеяться,
    И плакать, и шутить, и расставаться:
    Пока живу — должна душа страдать.
  {% endfilter %}
{% endblock %}
