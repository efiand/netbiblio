{% extends template %}

{% set title = "«Разливается благодать…»" %}
{% set workdate = "05.05.2002" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    Разливается благодать —
    И в душе тишина наступает.
    Освещенья, как праздника, ждать —
    И оно наши боли снимает.
  {% endfilter %}
{% endblock %}

{% block dateplace %}
  <time class="page__workdate" datetime="2002-05-05">05.05.2002 (Пасха)</time>
{% endblock %}
