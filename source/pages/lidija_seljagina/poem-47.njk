{% extends template %}

{% set title = "«То спрячется, то поглядит в оконце…»" %}
{% set workdate = "03.10.2018" %}
{% set pubdate = "05.11.2019" %}

{% block content %}
  {% filter poem %}
    То спрячется, то поглядит в оконце
    Осеннее волнующее солнце.
    И так душе становится тепло,
    Когда заглянет в комнату оно.
  {% endfilter %}
{% endblock %}
