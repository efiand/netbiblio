{% extends template %}

{% set title = "«Ах, личико! Когда-то молодое…»" %}
{% set workdate = "31.07.2005" %}
{% set pubdate = "17.04.2008" %}

{% block content %}
  {% filter poem %}
    Ах, личико! Когда-то молодое,
    Худенькое, нежно-золотое,
    Ты превратилось в крупное лицо,
    С каким не стыдно выйти на крыльцо.
  {% endfilter %}
{% endblock %}
