{% extends template %}

{% set title = "«В один прекрасный день с утра…»" %}
{% set pubdate = "17.04.2002" %}
{% set workplace = "Санкт-Петербург" %}

{% block content %}
  {% filter poem %}
    В один прекрасный день с утра
    Глубокий взгляд мной овладел.
    Любви воскресная пора
    Не предъявила свой предел.

    И радость искренне моя
    При каждой встрече повышалась.
    И в самом сердце у меня
    Высоких чувств струна игралась.
  {% endfilter %}
{% endblock %}

{% block dateplace %}
  <time class="page__workdate" datetime="2001-12">Декабрь 2001, {{ workplace }}</time>
{% endblock %}
