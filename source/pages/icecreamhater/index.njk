{% extends template %}

{% set title = "IceCreamHater" %}
{% set pubdate = "25.06.2011" %}
{% set contact = "//vk.com/icecreamhater" %}
{% set prev = "kiselev/index" %}
{% set next = "skromnaia/index" %}
{% set gender = "male" %}
{% set biographyHeading = "Об авторе" %}

{% block toc %}
  <h2 class="art__subtitle">Стихотворения</h2>
  <h3 class="page__toc-title">Осадки серого вещества</h3>
  {{ worksCollection("brain") }}

  <h3 class="page__toc-title">Femina religio</h3>
  {{ worksCollection("femina") }}

  <h2 class="art__subtitle">Малая проза</h2>
  <h3 class="page__toc-title">Мотивы и настроения</h3>
  <p class="page__subtitle-descr">(Короткие рассказы и эссе)</p>
  {{ worksCollection("moods") }}
{% endblock %}

{% block biography %}
  <p class="art__short">Настоящее имя — Иван Захаров.</p>
{% endblock %}
